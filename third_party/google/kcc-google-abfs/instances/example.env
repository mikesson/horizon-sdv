# ABFS on GKE (KCC/Helm) — per-instance values. This is the SAMPLE; copy it and fill in:
#   cp instances/example.env instances/my-instance.env   # edit the copy
#   scripts/render.sh instances/my-instance.env          # writes rendered/my-instance/
#   kubectl apply -k rendered/my-instance/infra
#   helm install abfs rendered/my-instance/chart/abfs -n abfs \
#     -f rendered/my-instance/chart/abfs/values.yaml      # then --set licensed=true (docs/04)
#
# Each KEY fills the token REPLACE_<KEY> wherever it appears in infra/ and chart/abfs/.
# Real instance files (instances/*.env) are git-ignored; only this sample is tracked.

# --- core data plane (required) ---
PROJECT_ID=my-gcp-project
HOST_PROJECT_ID=my-gcp-project        # Shared VPC: set to the host project; else = PROJECT_ID
NETWORK_NAME=vpc-abfs
ABFS_SUBNET_CIDR=10.0.0.0/24          # primary range of the ABFS subnet
SPANNER_CONFIG=regional-europe-west4  # Spanner instance config
BUCKET_NAME=my-gcp-project-abfs-blobs # GCS blob bucket (globally unique)
BUCKET_LOCATION=europe-west4

# --- ABFS runtime identity (the SA the whole data plane runs as) ---
# ABFS runs as ONE service account: the dedicated `abfs-data` node pool's node service
# account (GCE-metadata identity model — see docs/02 §1b), which MUST be in the license's
# allowed_service_accounts.
#   CREATE_RUNTIME_SAS=true  -> infra/10 creates RUNTIME_SA; request the license for it,
#                               then create the abfs-data pool with --service-account=it.
#   CREATE_RUNTIME_SAS=false -> RUNTIME_SA is a pre-existing, already-licensed SA;
#                               render.sh drops infra/10 and infra/12 binds roles by reference.
RUNTIME_SA=abfs-runtime
CREATE_RUNTIME_SAS=true

# --- Spanner schema ---
# The ABFS server does not create the schema at runtime, so the SpannerDatabase applies it
# declaratively (infra/schemas/<ver>-schema.sql, mirrored into infra/20-spanner.yaml spec.ddl).
#   true  -> apply that DDL on first deploy.   false -> blank it (seed the schema yourself; docs/04 §5).
# Do NOT change this after the database exists (data loss).
CREATE_TABLES=true

# --- CI/CD foundation (only needed when rendering infra/cicd/; safe to leave for the data plane) ---
# Regions: keep co-located with the data plane.
AR_REGION=europe-west4
SSM_REGION=europe-west4
CWS_REGION=europe-west4
CLOUD_BUILD_REGION=europe-west4
SCHEDULER_REGION=europe-west4

# Cloud Workstations host.
CWS_SUBNET_NAME=abfs-subnet
CWS_MACHINE_TYPE=n2-standard-32

# Secure Source Manager: upstream repo to clone into the SSM-hosted repo.
SSM_CLONE_URL=https://github.com/your-org/your-android-superproject.git
# SSM_REPO_URL is SERVER-ASSIGNED — read it from the repo's
# status.observedState.uris.gitHTTPS after 41-secure-source-manager.yaml reconciles, then set:
# SSM_REPO_URL=https://<instance>-<project>-git.<region>.sourcemanager.dev/<project>/<repo>.git

# Cloud Build trigger IDs are SERVER-ASSIGNED — fill in after 43-cloud-build.yaml reconciles
# (one per custom image):
# ANDROID_STUDIO_TRIGGER_ID=
# ASFP_TRIGGER_ID=
# CODE_OSS_TRIGGER_ID=

# Org-specific values:
# CWS_CREATOR=group:android-devs@example.com   # member that creates workstations (user:/group:/serviceAccount:)
# CWS_USER=group:android-devs@example.com       # member that uses workstations
# ALERT_EMAIL=oncall@example.com                # monitoring alert notifications
# CA_ORGANIZATION=Example Inc.                  # private SSM CA subject (PRIVATE SSM only)
# CA_COMMON_NAME=ABFS SSM Root CA
