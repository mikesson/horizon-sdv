// Description:
// AAOS SDV Build targets pipeline — same behaviour as AAOS Builder but Git HTTPS uses
// ~/.gitcookies decoded from build parameter GERRIT_GITCOOKIES_BASE64
//    (non-stored password; base64 of raw .gitcookies; see groovy/job.groovy).
// and/or (depending on GERRIT_AUTH_MODE)
// ~/.git-credentials decoded from build parameter GERRIT_GITCREDENTIALS_BASE64
//    (non-stored password; base64 of raw .git-credentials; see groovy/job.groovy)
// Scripts remain in aaos_builder/.

pipeline {

  // Parameters defined in workloads/android/pipelines/builds/aaos_sdv_builder/groovy/job.groovy

  agent none

  environment {
    GERRIT_API_URL="https://${env.HORIZON_DOMAIN}/gerrit"

    STORAGE_CLASS_SUFFIX="android-sdv"
    STORAGE_SIZE="1000Gi"

    // Define Pod Template in environment so we can override storageClassName.

    def kubernetesPodTemplate = """
      apiVersion: v1
      kind: Pod
      metadata:
        annotations:
          cluster-autoscaler.kubernetes.io/safe-to-evict: "true"
        labels:
          aaos_pod: "true"
      spec:
        tolerations:
        - key: workloadType
          operator: Equal
          value: android
          effect: "NoSchedule"
        affinity:
          podAntiAffinity:
            requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
                matchExpressions:
                - key: aaos_pod
                  operator: Exists
              topologyKey: kubernetes.io/hostname
        hostname: jenkins-aaos-build-pod
        serviceAccountName: ${JENKINS_SERVICE_ACCOUNT}
        containers:
        - name: builder
          image: ${CLOUD_REGION}-docker.pkg.dev/${CLOUD_PROJECT}/${ANDROID_BUILD_DOCKER_ARTIFACT_PATH_NAME}:latest
          imagePullPolicy: Always
          securityContext:
            privileged: true
            appArmorProfile:
              type: Unconfined
          command:
          - sleep
          args:
          - 5h
          resources:
            limits:
              cpu: 98000m
              memory: 180000Mi
            requests:
              cpu: 98000m
              memory: 180000Mi
          volumeMounts:
            - mountPath: /aaos-cache
              name: aaos-cache
        volumes:
          - name: aaos-cache
            ephemeral:
              volumeClaimTemplate:
                spec:
                  storageClassName: ${JENKINS_AAOS_BUILD_CACHE_STORAGE_PREFIX}-${STORAGE_CLASS_SUFFIX}
                  resources:
                    requests:
                      storage: ${STORAGE_SIZE}
                  accessModes:
                    - ReadWriteOnce
        nodeSelector:
          workloadLabel: android
    """.stripIndent()
  }

  stages {
    stage ('Start VM Instance') {
      agent { kubernetes { yaml kubernetesPodTemplate } }
      stages {
        stage ('Clean') {
          when {
            allOf {
              expression { env.AAOS_LUNCH_TARGET }
              expression { env.AAOS_CLEAN != 'NO_CLEAN' }
            }
          }
          steps {
            script {
              currentBuild.description = "${env.AAOS_LUNCH_TARGET}" + "<br/>" + "${env.AAOS_REVISION}" + "<br/>" + "${env.AAOS_MANIFEST_NAME}" + "<br/>" + "$BUILD_USER"
            }
            container(name: 'builder') {
              catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                sh '''
                  AAOS_LUNCH_TARGET="${AAOS_LUNCH_TARGET}" \
                  AAOS_CLEAN="${AAOS_CLEAN}" \
                  ./workloads/android/pipelines/builds/aaos_builder/aaos_environment.sh
                '''
              }
            }
          }
        }

        stage ('Initialise') {
          when {
            allOf {
              expression { env.AAOS_LUNCH_TARGET }
              expression { currentBuild.currentResult == 'SUCCESS' }
            }
          }
          steps {
            script {
              currentBuild.description = "${env.AAOS_LUNCH_TARGET}" + "<br/>" + "${env.AAOS_REVISION}" + "<br/>" + "${env.AAOS_MANIFEST_NAME}" + "<br/>" + "$BUILD_USER"
            }
            container(name: 'builder') {
              catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                script {
                  def authMode = (params.GERRIT_AUTH_MODE ?: 'auto').trim().toLowerCase()
                  def pvcHeader = '''
                    set +x
                    echo "AAOS CACHE Persistent Volume Claim: ${NODE_NAME}-aaos-cache" | tee -a build_cache_volume.txt
                    /usr/bin/kubectl get pod ${NODE_NAME} -n jenkins -o=jsonpath='{.spec.nodeName}' | xargs -I {} gcloud compute instances describe {} --zone=${CLOUD_ZONE} | grep 'deviceName: pvc' | awk '{print "AAOS CACHE Persistent Volume: " $2}' | tee -a build_cache_volume.txt || true
                  '''
                  def gitcookieSetup = '''
                    set -e
                    umask 077
                    EXIT_CODE=0
                    MSG_TYPE='INFO'
                    if [[ "${GERRIT_AUTH_MODE_RESOLVED}" == 'gitcookies' ]]; then
                      EXIT_CODE=1
                      MSG_TYPE='ERROR'
                    fi
                    printf '%s' "${GITCOOKIES_SECRET}" | tr -d '\n\r \t' | base64 -d > "${HOME}/.gitcookies" || {
                      echo "${MSG_TYPE}: GERRIT_GITCOOKIES_BASE64 must be base64-encoded .gitcookies (decode failed; invalid or truncated value?)" >&2
                      exit "${EXIT_CODE}"
                    }
                    chmod 600 "${HOME}/.gitcookies"
                    git config --global http.cookiefile "${HOME}/.gitcookies"
                    git config --global --unset-all credential.helper || true
                    rm -f "${HOME}/.git-credentials"
                    export GIT_TERMINAL_PROMPT=0
                    (
                      set +x
                      echo "gitcookies: HOME=${HOME}"
                      echo "gitcookies: input encoding=base64 (required)"
                      if ! test -s "${HOME}/.gitcookies"; then
                        echo "${MSG_TYPE}: ~/.gitcookies missing or empty after decode" >&2
                        exit "${EXIT_CODE}"
                      fi
                      echo "gitcookies: ~/.gitcookies bytes=$(wc -c < "${HOME}/.gitcookies" | awk '{print $1}')"
                      if command -v sha256sum >/dev/null 2>&1; then
                        echo "gitcookies: ~/.gitcookies sha256=$(sha256sum "${HOME}/.gitcookies" | awk '{print $1}')"
                      elif command -v shasum >/dev/null 2>&1; then
                        echo "gitcookies: ~/.gitcookies sha256=$(shasum -a 256 "${HOME}/.gitcookies" | awk '{print $1}')"
                      else
                        echo "gitcookies: sha256=unavailable (no sha256sum or shasum)"
                      fi
                      echo "gitcookies: http.cookiefile=$(git config --global --get http.cookiefile 2>/dev/null || echo unset)"
                      echo "gitcookies: ~/.gitconfig (after cookie setup; before aaos_initialise.sh):"
                      cat "${HOME}/.gitconfig" 2>/dev/null || echo "(no ${HOME}/.gitconfig)"
                    ) || exit 1
                  '''
                  def gitcredentialSetup = '''
                    set -e
                    umask 077
                    EXIT_CODE=0
                    MSG_TYPE='INFO'
                    if [[ "${GERRIT_AUTH_MODE_RESOLVED}" == 'username_password' ]]; then
                      EXIT_CODE=1
                      MSG_TYPE='ERROR'
                    fi

                    printf '%s' "${GITCREDENTIALS_SECRET}" | tr -d '\n\r \t' | base64 -d > "${HOME}/.git-credentials" || {
                      echo "${MSG_TYPE}: GERRIT_GITCREDENTIALS_BASE64 must be base64-encoded .git-credentials (decode failed; invalid or truncated value?)" >&2
                      exit "${EXIT_CODE}"
                    }
                    chmod 600 "${HOME}/.git-credentials"
                    git config --global credential.helper store
                    export GIT_TERMINAL_PROMPT=0
                    (
                      set +x
                      echo "git-credentials: HOME=${HOME}"
                      echo "git-credentials: input encoding=base64 (required)"
                      if ! test -s "${HOME}/.git-credentials"; then
                        echo "${MSG_TYPE}: ~/.git-credentials missing or empty after decode" >&2
                        exit "${EXIT_CODE}"
                      fi
                      echo "git-credentials: ~/.git-credentials bytes=$(wc -c < "${HOME}/.git-credentials" | awk '{print $1}')"
                      if command -v sha256sum >/dev/null 2>&1; then
                        echo "git-credentials: ~/.git-credentials sha256=$(sha256sum "${HOME}/.git-credentials" | awk '{print $1}')"
                      elif command -v shasum >/dev/null 2>&1; then
                        echo "git-credentials: ~/.git-credentials sha256=$(shasum -a 256 "${HOME}/.git-credentials" | awk '{print $1}')"
                      else
                        echo "git-credentials: sha256=unavailable (no sha256sum or shasum)"
                      fi
                      echo "git-credentials: ~/.gitconfig (after credentials setup; before aaos_initialise.sh):"
                      cat "${HOME}/.gitconfig" 2>/dev/null || echo "(no ${HOME}/.gitconfig)"
                    ) || exit 1
                  '''
                  def aaosInit = '''
                    AAOS_GERRIT_MANIFEST_URL="${AAOS_GERRIT_MANIFEST_URL}" \
                    AAOS_REVISION="${AAOS_REVISION}" \
                    AAOS_MANIFEST_NAME="${AAOS_MANIFEST_NAME}" \
                    AAOS_LUNCH_TARGET="${AAOS_LUNCH_TARGET}" \
                    AAOS_CLEAN="NO_CLEAN" \
                    GERRIT_SERVER_URL="${GERRIT_API_URL}" \
                    GERRIT_AUTH_MODE="${GERRIT_AUTH_MODE_RESOLVED}" \
                    GERRIT_USERNAME="" \
                    GERRIT_PASSWORD="" \
                    POST_REPO_INITIALISE_COMMAND="${POST_REPO_INITIALISE_COMMAND}" \
                    POST_REPO_COMMAND="${POST_REPO_COMMAND}" \
                    REPO_SYNC_JOBS="${GERRIT_REPO_SYNC_JOBS}" \
                    ./workloads/android/pipelines/builds/aaos_builder/aaos_initialise.sh
                  '''
                  if (authMode == 'none') {
                    withEnv(["GERRIT_AUTH_MODE_RESOLVED=${authMode}"]) {
                      sh pvcHeader + aaosInit
                    }
                  } else {
                    def gitcookiesB64 = (params.GERRIT_GITCOOKIES_BASE64 != null ? params.GERRIT_GITCOOKIES_BASE64 : '').toString().trim()
                    def gitcredentialsB64 = (params.GERRIT_GITCREDENTIALS_BASE64 != null ? params.GERRIT_GITCREDENTIALS_BASE64 : '').toString().trim()
                    if (authMode == 'gitcookies' && !gitcookiesB64) {
                      error('Set build parameter GERRIT_GITCOOKIES_BASE64 (non-stored: base64-encoded raw .gitcookies, one line) or use GERRIT_AUTH_MODE: none or username_password')
                    }
                    if (authMode == 'username_password' && !gitcredentialsB64) {
                      error('Set build parameter GERRIT_GITCREDENTIALS_BASE64 (non-stored: base64-encoded raw .git-credentials, one line) or use GERRIT_AUTH_MODE: none or gitcookies')
                    }
                    maskPasswords(varPasswordPairs: [[var: 'GITCOOKIES_SECRET'],[var: 'GITCREDENTIALS_SECRET']], varMaskRegexes: []) {
                      withEnv([
                        "GITCOOKIES_SECRET=${gitcookiesB64}",
                        "GITCREDENTIALS_SECRET=${gitcredentialsB64}",
                        "GERRIT_AUTH_MODE_RESOLVED=${authMode}",
                      ]) {
                        sh pvcHeader + gitcookieSetup + gitcredentialSetup + aaosInit
                      }
                    }
                  }
                }
              }
              archiveArtifacts artifacts: 'build_cache*.txt', followSymlinks: false, onlyIfSuccessful: false, allowEmptyArchive: true
            }
          }
        }

        stage ('Build'){
          when {
            allOf {
              expression { env.AAOS_LUNCH_TARGET }
              expression { currentBuild.currentResult == 'SUCCESS' }
            }
          }
          steps {
            container(name: 'builder') {
              catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                sh '''
                  AAOS_LUNCH_TARGET="${AAOS_LUNCH_TARGET}" \
                  AAOS_BUILD_CTS=${AAOS_BUILD_CTS} \
                  ./workloads/android/pipelines/builds/aaos_builder/aaos_build.sh
                '''
              }
              archiveArtifacts artifacts: 'aaos-build*.log', followSymlinks: false, onlyIfSuccessful: false, allowEmptyArchive: true
            }
          }
        }

        stage ('Storage') {
          when {
            allOf {
              expression { env.AAOS_LUNCH_TARGET }
              expression { env.AAOS_ARTIFACT_STORAGE_SOLUTION }
              expression { currentBuild.currentResult == 'SUCCESS' }
            }
          }
          steps {
            container(name: 'builder') {
              catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                script {
                  env.AAOS_BUILD_STAGE_FAILED = (currentBuild.currentResult != 'SUCCESS') ? 'true' : 'false'
                }
                sh '''
                  if [ "${AAOS_BUILD_STAGE_FAILED}" != "true" ]; then
                    AAOS_LUNCH_TARGET="${AAOS_LUNCH_TARGET}" \
                    AAOS_REVISION="${AAOS_REVISION}" \
                    ANDROID_VERSION="${ANDROID_VERSION}" \
                    ./workloads/android/pipelines/builds/aaos_builder/aaos_avd_sdk.sh || true
                  fi

                  AAOS_LUNCH_TARGET="${AAOS_LUNCH_TARGET}" \
                  AAOS_ARTIFACT_ROOT_NAME="${ANDROID_BUILD_BUCKET_ROOT_NAME}" \
                  AAOS_ARTIFACT_STORAGE_SOLUTION="${AAOS_ARTIFACT_STORAGE_SOLUTION}" \
                  STORAGE_BUCKET_DESTINATION="${STORAGE_BUCKET_DESTINATION}" \
                  STORAGE_LABELS="${STORAGE_LABELS}" \
                  AAOS_BUILD_STAGE_FAILED="${AAOS_BUILD_STAGE_FAILED}" \
                  ./workloads/android/pipelines/builds/aaos_builder/aaos_storage.sh
                '''
                archiveArtifacts artifacts: '*artifacts*.txt', followSymlinks: false, onlyIfSuccessful: false, allowEmptyArchive: true
              }
            }
          }
        }

        stage ('Retain instance') {
          when { expression { env.AAOS_LUNCH_TARGET } }
          steps {
            container(name: 'builder') {
              script {
                sleep(time: "${INSTANCE_RETENTION_TIME}", unit: 'MINUTES')
              }
            }
          }
        }
      }
    }
  }
}
